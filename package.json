{
  "name": "ebcenter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:docker": "docker compose up -d postgres && npx wait-on tcp:localhost:5432 -t 30000 && yarn dev",
    "docker:up": "docker compose up -d postgres",
    "docker:down": "docker compose down",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "db:migrate": "yarn payload migrate",
    "db:migrate:create": "yarn payload migrate:create",
    "generate:importmap": "yarn payload generate:importmap",
    "migrate:content": "yarn payload run scripts/migrate-content.ts",
    "seed": "npx tsx scripts/seed.ts",
    "deploy:prepare": "npx cross-env NODE_OPTIONS=--no-deprecation payload migrate && npx tsx scripts/seed.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.6.1",
    "@payloadcms/db-postgres": "^3.77",
    "@payloadcms/live-preview-react": "^3.78.0",
    "@payloadcms/next": "^3.77",
    "@payloadcms/richtext-lexical": "^3.77",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/negotiator": "^0.6.3",
    "@types/react-input-mask": "^3.0.6",
    "@vercel/analytics": "^1.5.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "false": "^0.0.4",
    "graphql": "^16.13.0",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.0.4",
    "i18next-resources-to-backend": "^1.2.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.544.0",
    "negotiator": "^1.0.0",
    "next": "15.2.4",
    "next-i18next": "^15.4.2",
    "next-international": "^1.3.1",
    "next-turnstile": "^1.0.2",
    "payload": "^3.77",
    "react": "^19.0.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.1",
    "react-input-mask": "^2.0.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.8"
  },
  "optionalDependencies": {
    "@img/sharp-linux-x64": "0.34.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
